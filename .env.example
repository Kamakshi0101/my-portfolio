# SMTP configuration for contact form API
# Copy to .env.local and fill with real values
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password

# Coding stats API behavior
# static: use values from data/codingStats.json
# live: fetch from real coding profiles/APIs
LIVE_STATS_MODE=live

# Optional: improves GitHub API reliability/rate limits in production
GITHUB_TOKEN=your_github_personal_access_token
